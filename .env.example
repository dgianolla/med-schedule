# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/schedule_db

# AppHealth Integration
APPHEALTH_BASE_URL=https://back.apphealth.com.br:9090/api-vita
APPHEALTH_API_KEY=<token>

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Logging
LOG_LEVEL=info

# Environment
ENV=development

# API Configuration
API_PREFIX=/api/v1
